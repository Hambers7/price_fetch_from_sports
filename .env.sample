GAMMA_BASE_URL=https://gamma-api.polymarket.com
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
MARKET_SLUG=atp-kuzuhar-andrade-2026-04-07
MAX_MARKETS=10
# Page size / max pages when using: npm run dev -- --soccer-matches
DISCOVER_EVENTS_PAGE_SIZE=100
DISCOVER_MAX_PAGES=30
REFRESH_MARKETS_MS=600000

# CLOB full order-book bid totals (green YES / red NO / combined total)
# BOOK_DEPTH_ENABLED=0
# BOOK_DEPTH_POLL_MS=2000

# --- Trading (CLOB v2) — never commit real keys ---
# Fixed share count used by hotkeys "1" and "2" (BUY YES / BUY NO).
# Change requires restarting the dev process.
SHARES=10
# Polymarket minimum buy notional in USD (~$1 if unset). Used for hotkeys 1/2/4/5.
# Hotkeys 7/8 (sell all) are not blocked by this — you can exit positions below $1 notional.
MIN_ORDER_USD=1
# USD notional used by hotkeys "4" / "5" (BUY $X YES / NO at current best ask).
# Shares are computed at trade time as floor(BUY_USD / askPrice). Default $100.
BUY_USD=100
# Optional: JSON file for persisted trade journal + closed trades + ledgers (default: .price-fetch-trade-history.json in cwd)
# TRADE_HISTORY_FILE=

POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
# 0=EOA, 1=POLY_PROXY, 2=POLY_GNOSIS_SAFE, 3=POLY_1271
POLYMARKET_SIGNATURE_TYPE=2
POLYMARKET_RPC_URL=https://polygon-rpc.com
